# Meridian Estates — environment variables
# Copy to .env.local and fill real values. Never commit .env.local.

# AI provider key — powers the AI Property Matcher (spec §5) and the site chatbot.
# Default provider is xAI Grok (OpenAI-compatible), consumed via lib/ai.ts. If missing
# or invalid, /api/matcher and /api/chat degrade gracefully (fallback: true).
GROK_API_KEY=

# Optional provider overrides (defaults shown; the app works without setting these):
#   AI_API_KEY takes precedence over GROK_API_KEY, letting you point at any
#   OpenAI-compatible endpoint without code changes.
# AI_API_KEY=
# AI_BASE_URL=https://api.x.ai/v1
# AI_MODEL=grok-3
# AI_PROVIDER=grok

# WhatsApp advisor number in international format, digits only, no "+" (spec §12).
# Example UAE mobile: 9715XXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Neon PostgreSQL connection string — consumed by Prisma.
DATABASE_URL=
