# Meridian Estates — environment variables
# Copy to .env.local and fill real values. Never commit .env.local.

# AI provider key — powers the AI Property Matcher (spec §5) and the site chatbot,
# consumed via lib/ai.ts (OpenAI-compatible). If missing or invalid, /api/matcher
# and /api/chat degrade gracefully (fallback: true). The client is provider-agnostic;
# set AI_* below to point at any OpenAI-compatible endpoint without code changes.
#
# Example — Google Gemini (active in this project):
# AI_API_KEY=
# AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# AI_MODEL=gemini-2.5-flash
# AI_PROVIDER=gemini
# AI_REASONING_EFFORT=none   # disable "thinking" so it doesn't eat the reply budget
#
# Example — xAI Grok:
# AI_BASE_URL=https://api.x.ai/v1
# AI_MODEL=grok-3
# AI_PROVIDER=grok
GROK_API_KEY=
AI_API_KEY=

# WhatsApp advisor number in international format, digits only, no "+" (spec §12).
# Example UAE mobile: 9715XXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=

# Neon PostgreSQL connection string — consumed by Prisma.
DATABASE_URL=
