# Keep the build context small and secrets out of the image.

# dependencies (reinstalled inside the image via npm ci)
node_modules
.pnp
.pnp.js

# build output (regenerated by `next build` in the builder stage)
.next
out
build

# secrets & local env — NEVER copy these into the image. Server-only vars are
# injected at `docker run` (-e); NEXT_PUBLIC_* vars come in as --build-arg.
.env
.env.local
.env*.local

# vcs & tooling
.git
.gitignore
.dockerignore
Dockerfile

# misc / editor / OS
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# logs & docs not needed at runtime
dev.log
